# =============================================================================
# Cold Spring Liquor — Environment Variables Template
# Copy this file → .env.local in each app folder and fill in real values.
# NEVER commit .env.local or any real secret keys to GitHub.
# =============================================================================

# ── Supabase (get from supabase.com → Project Settings → API) ────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ── App URLs (update when deploying to Vercel) ────────────────────────────────
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_DRIVER_URL=http://localhost:3002

# ── Stripe (optional — for real payments) ────────────────────────────────────
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ── Twilio (optional — for real SMS OTP) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# ── Google OAuth (optional — for real Google login) ──────────────────────────
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
